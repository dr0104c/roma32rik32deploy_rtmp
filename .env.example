POSTGRES_DB=stream_platform
POSTGRES_USER=stream_platform
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql+psycopg://stream_platform:change-me-db-password@postgres:5432/stream_platform
ADMIN_SECRET=change-me-admin-secret
INTERNAL_API_SECRET=change-me-internal-secret
PLAYBACK_TOKEN_SECRET=change-me-playback-secret
VIEWER_SESSION_SECRET=change-me-viewer-secret
TURN_SHARED_SECRET=change-me-turn-secret
TURN_REALM=stream.local
PUBLIC_HOST=127.0.0.1
PUBLIC_BASE_URL=http://127.0.0.1:8080
WEBRTC_PUBLIC_BASE_URL=http://127.0.0.1:8080/webrtc
DOMAIN_NAME=
ACME_EMAIL=
ENABLE_TLS=false
ENABLE_AUTOMATED_MEDIA_VERIFY=true
STUN_URLS=stun:127.0.0.1:3478
TURN_URLS=turn:127.0.0.1:3478?transport=udp,turn:127.0.0.1:3478?transport=tcp
TURN_EXTERNAL_IP=
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
RTMP_PORT=1935
WEBRTC_HTTP_PORT=8889
WEBRTC_ICE_PORT=8189
TURN_PORT=3478
TURN_TLS_PORT=5349
VIEWER_SESSION_TTL_SECONDS=86400
PLAYBACK_TOKEN_TTL_SECONDS=120
STREAM_LIST_POLL_INTERVAL_SECONDS=5
LOG_LEVEL=INFO
ACCESS_LOG_ENABLED=true
MEDIAMTX_LOG_LEVEL=info
INGEST_AUTH_MODE=open
INTERNAL_MEDIA_SECRET_REQUIRED=true
ENABLE_FFMPEG_TRANSCODE=false
VERIFY_TURN=true
VERIFY_BROWSERLESS_WHEP=true
VERIFY_RTMP_PLAYBACK_BLOCK=true
VERIFY_REPORT_DIR=deploy
MEDIA_SMOKE_TEST_DURATION_SEC=12
MEDIA_SMOKE_TEST_STREAM_NAME=verification-smoke
BACKUP_RETENTION=7
SSH_PORT=22
SSH_KEY_ONLY=false
